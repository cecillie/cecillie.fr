{% extends ['list.html.twig', '_default/list.html.twig'] %}

      {%- block content ~%}
      <article class="mx-auto max-w-(--breakpoint-md) prose md:prose-lg lg:prose-xl
        prose-h2:text-base prose-img:m-0 prose-a:no-underline
      ">
        <h1>{{ page.title }}</h1>
        {{- page.content ~}}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {%- for p in pages ~%}
          <a class="text-center" href="{{ url(p) }}">
            <h2>{{ p.title }}</h2>
            {{- html(asset(p.images[0].file), options={responsive: 'density', formats: ['avif', 'webp']}, attributes={alt: p.images[0].alt|e, width: 400}) ~}}
          </a>
          {%- endfor ~%}
        </div>
      </article>
      {%- endblock content ~%}

    {%- block noise %}{% endblock ~%}