{% set image = 'images/' ~ page.id ~ '/' ~ page.images[0].file %}

{% extends ['page.html.twig', '_default/page.html.twig'] %}

    {%- block head ~%}
    {{- parent() ~}}
    <style>{% apply minify_css ~%}
      {{ asset('https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css', {minify: false})|inline }}
      :root {
        --swiper-navigation-color: #000;
        --swiper-pagination-color: #000;
      }
    {% endapply ~%}</style>
    {%- endblock ~%}

      {%- block content ~%}
      <article class="mx-auto max-w-(--breakpoint-md) prose md:prose-lg lg:prose-xl
        prose-img:mx-auto prose-figcaption:text-center prose-img:m-0 prose-picture:m-0 lg:prose-img:mb-1
      ">
        <header class="mb-4">
          <h1>{{ page.title }}</h1>
          <time>{{ page.date|format_date('long') }}</time>
        </header>
        <div class="swiper">
          <div class="swiper-wrapper">
            {%- for img in page.images ~%}
            <div class="swiper-slide">
              {%- set attributes = {alt: img.alt|e, width: 540} -%}
              {%- if loop.index == 1 -%}
                {%- set attributes = attributes|merge({loading: 'eager', fetchpriority: 'high'}) -%}
              {%- else -%}
                {%- set attributes = attributes|merge({loading: 'lazy'}) -%}
              {%- endif ~%}
              {{ html(asset('images/' ~ page.id ~ '/' ~ img.file), options={responsive: 'density', formats: ['avif', 'webp']}, attributes=attributes) ~}}
            </div>
            {%- endfor ~%}
          </div>
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
          <div class="swiper-pagination"></div>
        </div>
        {{~ page.content ~}}
      </article>
      {%- endblock content ~%}

    {%- block scripts ~%}
    {{- parent() ~}}
    <script>{% apply minify_js ~%}
      {{ asset('https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js', {minify: false})|inline }}
      const swiper = new Swiper('.swiper', {
        navigation: {
          nextEl: '.swiper-button-next',
          prevEl: '.swiper-button-prev',
        },
        pagination: {
          el: '.swiper-pagination',
        },
      });
    {% endapply ~%}</script>
    {%- endblock ~%}